# Copy this file to ".env" and fill in your own values for local development.

# A long random string used by Django for signing. Change it for production.
SECRET_KEY=Pratham

# Set to True locally, False in production.
DEBUG=True

# Leave blank to use the local SQLite database. In production point this at
# your Postgres/Supabase connection string.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Comma separated list of extra origins allowed to call the API
# (e.g. your deployed React URL on Vercel).
# CORS_EXTRA_ORIGINS=https://your-frontend.vercel.app
